#!/usr/bin/env bash
# Emit KEY=value lines for the runner's sandbox env:
#   GH_TOKEN=<token>         — GitHub personal-access token (from macOS Keychain)
#   GH_REPO=<owner>/<repo>   — GitHub repo, derived from the host repo's origin remote
#
# Usage (invoked by the runner's collect_binding_env hook):
#   sandbox-env
#
# Output:
#   stdout — GH_TOKEN=<token> followed by GH_REPO=owner/repo
#   stderr — diagnostics on failure. The token is NEVER written to stderr.
#
# Exit codes:
#   0 — both lines printed
#   1 — Keychain entry missing/unreadable, no origin remote, or non-github.com origin
#   2 — environment problem (OS unsupported, 'security' binary absent).
#
# Keychain coordinates (macOS):
#   service: formann-gh-token
#   account: github
#
# To populate (one-time setup):
#   security add-generic-password -s formann-gh-token -a github -w
#   (paste your GitHub token at the prompt — no trailing newline)
#
# Linux: store the token via libsecret or keyctl and export GH_TOKEN before
# invoking the runner. Direct Keychain integration on Linux is not implemented
# here; the script exits 2 on Linux.

set -euo pipefail

GH_KEYCHAIN_SERVICE="formann-gh-token"
GH_KEYCHAIN_ACCOUNT="github"

if [[ "$OSTYPE" == darwin* ]]; then
  if ! command -v security >/dev/null 2>&1; then
    echo "sandbox-env: 'security' binary not found; cannot retrieve GH token from Keychain" >&2
    exit 2
  fi

  token=""
  if ! token="$(security find-generic-password \
      -s "$GH_KEYCHAIN_SERVICE" \
      -a "$GH_KEYCHAIN_ACCOUNT" \
      -w 2>/dev/null)"; then
    cat >&2 <<MSG
sandbox-env: GH token not found in Keychain
  service: $GH_KEYCHAIN_SERVICE
  account: $GH_KEYCHAIN_ACCOUNT

To populate (one-time, then good until the token expires):
  security add-generic-password -s "$GH_KEYCHAIN_SERVICE" -a "$GH_KEYCHAIN_ACCOUNT" -w
  (paste your GitHub personal-access token at the prompt — no trailing newline)
MSG
    exit 1
  fi

  if [[ -z "$token" ]]; then
    echo "sandbox-env: Keychain entry found but token is empty" >&2
    exit 1
  fi

  printf 'GH_TOKEN=%s\n' "$token"

  # Derive GH_REPO from the host repo's origin remote (resolved via CWD).
  _repo_root=""
  if ! _repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "sandbox-env: not inside a git repository; cannot derive GH_REPO" >&2
    exit 1
  fi

  _origin_url=""
  if ! _origin_url="$(git -C "$_repo_root" remote get-url origin 2>/dev/null)"; then
    echo "sandbox-env: host repository has no 'origin' remote; cannot derive GH_REPO" >&2
    exit 1
  fi

  _gh_host=""
  _owner_repo=""

  if [[ "$_origin_url" =~ ^git@([^:]+):(.+)$ ]]; then
    _gh_host="${BASH_REMATCH[1]}"
    _owner_repo="${BASH_REMATCH[2]%.git}"
  elif [[ "$_origin_url" =~ ^ssh://([^@/]+@)?([^:/]+)(:[0-9]+)?/(.+)$ ]]; then
    _gh_host="${BASH_REMATCH[2]}"
    _owner_repo="${BASH_REMATCH[4]%.git}"
  elif [[ "$_origin_url" =~ ^https://([^@/]+@)?([^/]+)/(.+)$ ]]; then
    _gh_host="${BASH_REMATCH[2]}"
    _owner_repo="${BASH_REMATCH[3]%.git}"
  else
    echo "sandbox-env: origin remote '$_origin_url' is not a recognised SSH or HTTPS URL" >&2
    exit 1
  fi

  if [[ "$_gh_host" != "github.com" ]]; then
    echo "sandbox-env: origin remote hostname '$_gh_host' is not 'github.com'; only github.com is supported" >&2
    exit 1
  fi

  if [[ ! "$_owner_repo" =~ ^[^/]+/[^/]+$ ]]; then
    echo "sandbox-env: origin remote '$_origin_url' does not have owner/repo shape (got '$_owner_repo')" >&2
    exit 1
  fi

  printf 'GH_REPO=%s\n' "$_owner_repo"

else
  cat >&2 <<MSG
sandbox-env: OS '$OSTYPE' is not supported by this script.
On Linux, export GH_TOKEN in your shell before invoking the runner.
MSG
  exit 2
fi
